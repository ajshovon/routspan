# Auto-detect text files and normalize line endings to LF.
* text=auto eol=lf

# Windows-only scripts keep CRLF; the Unix wrapper script keeps LF.
*.bat text eol=crlf
/android/gradlew text eol=lf
/android/gradlew.bat text eol=crlf

# Binary assets — never diff/convert these.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.keystore binary
*.jks binary
